# クラスターテスト用 Docker Compose 設定
# プロジェクト名: {{ project.name }}
# バージョン: {{ project.version }}

x-ray-environment: &ray-environment
  HEAD_WHITELIST: "{{ nodes.head_whitelist | join(' ') }}"
  HEAD_ADDRESS_CFG: "{{ nodes.head_address or '' }}"
  HEALTH_URL: {{ nodes.health_service.url }}
  HEALTH_TIMEOUT: {{ nodes.health_service.timeout }}
  HEALTH_MAX_RETRIES: {{ nodes.health_service.max_retries }}
  HEALTH_RETRY_INTERVAL: {{ nodes.health_service.retry_interval }}
  DISCOVERY_TIMEOUT: {{ nodes.cluster.discovery_timeout }}
  WAIT_FOR_HEAD: {{ nodes.cluster.wait_for_head }}

{% set ray_target = cluster_test.target %}
{% set d = services.ray.default %}
{% set cpu = services.ray.cpu %}
{% set gpu = services.ray.gpu %}

{% set cpu_image = cpu.image or d.image %}
{% set cpu_build = cpu.build or d.build %}
{% set cpu_cpus = cpu.cpus or d.cpus %}
{% set cpu_memory = cpu.memory or d.memory %}
{% set cpu_head_port = cpu.head_port or d.head_port %}
{% set cpu_dashboard_port = cpu.dashboard_port or d.dashboard_port %}
{% set cpu_client_port = cpu.client_port or d.client_port %}
{% set cpu_node_ip_address = cpu.node_ip_address or d.node_ip_address %}
{% set cpu_node_manager_port = cpu.node_manager_port or d.node_manager_port %}
{% set cpu_object_manager_port = cpu.object_manager_port or d.object_manager_port %}
{% set cpu_min_worker_port = cpu.min_worker_port or d.min_worker_port %}
{% set cpu_max_worker_port = cpu.max_worker_port or d.max_worker_port %}

{% set gpu_image = gpu.image or d.image %}
{% set gpu_build = gpu.build or d.build %}
{% set gpu_cpus = gpu.cpus or d.cpus %}
{% set gpu_memory = gpu.memory or d.memory %}
{% set gpu_head_port = gpu.head_port or d.head_port %}
{% set gpu_dashboard_port = gpu.dashboard_port or d.dashboard_port %}
{% set gpu_client_port = gpu.client_port or d.client_port %}
{% set gpu_node_ip_address = gpu.node_ip_address or d.node_ip_address %}
{% set gpu_node_manager_port = gpu.node_manager_port or d.node_manager_port %}
{% set gpu_object_manager_port = gpu.object_manager_port or d.object_manager_port %}
{% set gpu_min_worker_port = gpu.min_worker_port or d.min_worker_port %}
{% set gpu_max_worker_port = gpu.max_worker_port or d.max_worker_port %}
{% set gpu_num_gpus = gpu.num_gpus %}
{% set gpu_runtime = gpu.runtime %}

{% set target_host = "ray-gpu" if ray_target == "gpu" else "ray-cpu" %}
{% set target_head_port = gpu_head_port if ray_target == "gpu" else cpu_head_port %}
{% set target_dashboard_port = gpu_dashboard_port if ray_target == "gpu" else cpu_dashboard_port %}
{% set target_client_port = gpu_client_port if ray_target == "gpu" else cpu_client_port %}

x-ray: &ray
  restart: unless-stopped

services:
{% if services.health.enabled %}
  health:
    image: python:3.12-alpine
    container_name: {{ project.name }}-health
    volumes:
      - ../entrypoints/health.py:/app/health.py:ro
    command: ["python3", "/app/health.py"]
    ports:
      - "0.0.0.0:{{ services.health.port }}:8080"
    healthcheck:
      test: ["CMD", "python3", "-c", "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080', timeout=1)"]
      interval: 5s
      timeout: 3s
      retries: 10
      start_period: 3s
    networks:
      - ray-network
{% endif %}

  ray-cpu:
    <<: *ray
    image: {{ cpu_image }}
{% if cpu_build and cpu_build.enabled %}
    build:
      context: {{ cpu_build.context }}
      dockerfile: {{ cpu_build.dockerfile }}
      target: {{ cpu_build.target }}
{% endif %}
    container_name: {{ project.name }}-ray-cpu
    hostname: ray-cpu
    restart: "no"
    shm_size: '2gb'
    environment:
      <<: *ray-environment
      RAY_HEAD_PORT: {{ cpu_head_port }}
      RAY_DASHBOARD_PORT: {{ cpu_dashboard_port }}
      RAY_CLIENT_PORT: {{ cpu_client_port }}
    {% if cpu_node_ip_address %}
      NODE_IP_ADDRESS: {{ cpu_node_ip_address }}
    {% endif %}
    {% if cpu_node_manager_port %}
      NODE_MANAGER_PORT: {{ cpu_node_manager_port }}
    {% endif %}
    {% if cpu_object_manager_port %}
      OBJECT_MANAGER_PORT: {{ cpu_object_manager_port }}
    {% endif %}
    {% if cpu_min_worker_port %}
      MIN_WORKER_PORT: {{ cpu_min_worker_port }}
    {% endif %}
    {% if cpu_max_worker_port %}
      MAX_WORKER_PORT: {{ cpu_max_worker_port }}
    {% endif %}
{% if cpu_cpus %}
      RAY_NUM_CPUS: {{ cpu_cpus }}
{% endif %}
{% if cpu_build and cpu_build.enabled %}
      USE_CONDA_ENV: "1"
{% endif %}
    volumes:
      - ../entrypoints/ray.sh:/app/ray.sh:ro
      - ../_build/logs/ray-cpu/tmp-ray:/tmp/ray
    user: root
{% if cpu_build and cpu_build.enabled %}
    entrypoint: ["/bin/bash", "-c", "/app/ray.sh"]
{% else %}
    entrypoint: ["/bin/bash", "-c", "su -m ray -c '/app/ray.sh'"]
{% endif %}
{% if services.health.enabled %}
    depends_on:
      health:
        condition: service_healthy
{% endif %}
{% if cpu_cpus or cpu_memory %}
    deploy:
      resources:
        limits:
{% if cpu_cpus %}
          cpus: "{{ cpu_cpus }}"
{% endif %}
{% if cpu_memory %}
          memory: {{ cpu_memory }}
{% endif %}
{% endif %}
    ports:
      - "{{ cpu_dashboard_port }}:{{ cpu_dashboard_port }}"
      - "{{ cpu_client_port }}:{{ cpu_client_port }}"
      - "{{ cpu_head_port }}:{{ cpu_head_port }}"
    networks:
      - ray-network

{% if host.has_gpu %}
  ray-gpu:
    <<: *ray
    image: {{ gpu_image }}
{% if gpu_build and gpu_build.enabled %}
    build:
      context: {{ gpu_build.context }}
      dockerfile: {{ gpu_build.dockerfile }}
      target: {{ gpu_build.target }}
{% endif %}
    container_name: {{ project.name }}-ray-gpu
    hostname: ray-gpu
    restart: "no"
    shm_size: '2gb'
    environment:
      <<: *ray-environment
      RAY_HEAD_PORT: {{ gpu_head_port }}
      RAY_DASHBOARD_PORT: {{ gpu_dashboard_port }}
      RAY_CLIENT_PORT: {{ gpu_client_port }}
      RAY_NUM_GPUS: {{ gpu_num_gpus }}
    {% if gpu_node_ip_address %}
      NODE_IP_ADDRESS: {{ gpu_node_ip_address }}
    {% endif %}
    {% if gpu_node_manager_port %}
      NODE_MANAGER_PORT: {{ gpu_node_manager_port }}
    {% endif %}
    {% if gpu_object_manager_port %}
      OBJECT_MANAGER_PORT: {{ gpu_object_manager_port }}
    {% endif %}
    {% if gpu_min_worker_port %}
      MIN_WORKER_PORT: {{ gpu_min_worker_port }}
    {% endif %}
    {% if gpu_max_worker_port %}
      MAX_WORKER_PORT: {{ gpu_max_worker_port }}
    {% endif %}
{% if gpu_cpus %}
      RAY_NUM_CPUS: {{ gpu_cpus }}
{% endif %}
{% if gpu_build and gpu_build.enabled %}
      USE_CONDA_ENV: "1"
{% endif %}
    volumes:
      - ../entrypoints/ray.sh:/app/ray.sh:ro
      - ../_build/logs/ray-gpu/tmp-ray:/tmp/ray
    user: root
{% if gpu_build and gpu_build.enabled %}
    entrypoint: ["/bin/bash", "-c", "/app/ray.sh"]
{% else %}
    entrypoint: ["/bin/bash", "-c", "su -m ray -c '/app/ray.sh'"]
{% endif %}
{% if services.health.enabled %}
    depends_on:
      health:
        condition: service_healthy
{% endif %}
    deploy:
      resources:
        reservations:
          devices:
            - driver: {{ gpu_runtime }}
              count: all
              capabilities: [gpu]
{% if gpu_cpus or gpu_memory %}
        limits:
{% if gpu_cpus %}
          cpus: "{{ gpu_cpus }}"
{% endif %}
{% if gpu_memory %}
          memory: {{ gpu_memory }}
{% endif %}
{% endif %}
    ports:
      - "{{ gpu_dashboard_port }}:{{ gpu_dashboard_port }}"
      - "{{ gpu_client_port }}:{{ gpu_client_port }}"
      - "{{ gpu_head_port }}:{{ gpu_head_port }}"
    networks:
      - ray-network
{% endif %}

  test-ray-client:
    <<: *ray
    image: {{ gpu_image if ray_target == "gpu" else cpu_image }}
    container_name: {{ project.name }}-test-client
    hostname: test-ray-client
    restart: "no"
    shm_size: '1gb'
    extra_hosts:
      - "{{ target_host }}:{{ host.ip_address }}"
      - "health:{{ host.ip_address }}"
    environment:
      <<: *ray-environment
      RAY_HEAD_PORT: {{ target_head_port }}
      RAY_DASHBOARD_PORT: {{ target_dashboard_port }}
      RAY_CLIENT_PORT: {{ target_client_port }}
      RAY_PYTHON_BIN: "${RAY_PYTHON_BIN:-python3}"
      RAY_NUM_CPUS: "1"
    volumes:
      - ../entrypoints/ray.sh:/app/ray.sh:ro
      - ../_build/logs/test-client/tmp-ray:/tmp/ray
    user: root
    entrypoint: ["/bin/bash", "-c"]
    command:
      - |
        apt-get update -qq && apt-get install -y -qq curl iputils-ping dnsutils > /dev/null 2>&1
        echo "=== Test Ray Client Network Test ==="
        echo "Testing connectivity to main cluster..."

        ping -c 2 {{ target_host }} || echo "⚠ Cannot ping {{ target_host }}"
      {% if services.health.enabled %}
        ping -c 2 health || echo "⚠ Cannot ping health"
      {% endif %}

        timeout 2 bash -c "</dev/tcp/{{ target_host }}/{{ target_head_port }}" && echo "✓ {{ target_host }}:{{ target_head_port }} reachable" || echo "✗ {{ target_host }}:{{ target_head_port }} unreachable"
        {% if services.health.enabled %}
          timeout 2 bash -c "</dev/tcp/health/{{ services.health.port }}" && echo "✓ health:{{ services.health.port }} reachable" || echo "✗ health:{{ services.health.port }} unreachable"
        {% endif %}

        echo ""
        echo "Testing Ray client connection..."
        su - ray -c "$$RAY_PYTHON_BIN -c 'import ray; ray.init(\"ray://{{ host.ip_address }}:{{ target_client_port }}\", ignore_reinit_error=True); print(\"✓ Ray client connected\"); print(\"Resources:\", ray.cluster_resources()); ray.shutdown()' || echo '✗ Ray client connection failed'"

        echo ""
        echo "Test client container will sleep for debugging..."
        tail -f /dev/null
    depends_on:
      - {{ target_host }}
{% if services.health.enabled %}
      - health
{% endif %}
    networks:
      - test-network

  test-ray-worker:
    <<: *ray
    image: {{ gpu_image if ray_target == "gpu" else cpu_image }}
    container_name: {{ project.name }}-test-worker
    hostname: test-ray-worker
    restart: "no"
    shm_size: '1gb'
    extra_hosts:
      - "{{ target_host }}:{{ host.ip_address }}"
      - "health:{{ host.ip_address }}"
    environment:
      <<: *ray-environment
      RAY_HEAD_PORT: {{ target_head_port }}
      RAY_DASHBOARD_PORT: {{ target_dashboard_port }}
      RAY_CLIENT_PORT: {{ target_client_port }}
      NODE_MANAGER_PORT: {{ cluster_test.worker_node_manager_port }}
      OBJECT_MANAGER_PORT: {{ cluster_test.worker_object_manager_port }}
      MIN_WORKER_PORT: {{ cluster_test.worker_min_worker_port }}
      MAX_WORKER_PORT: {{ cluster_test.worker_max_worker_port }}
      RAY_NUM_CPUS: "2"
      HEAD_ADDRESS: "{{ target_host }}:{{ target_head_port }}"
    volumes:
      - ../entrypoints/ray.sh:/app/ray.sh:ro
      - ../_build/logs/test-worker/tmp-ray:/tmp/ray
    user: root
    entrypoint: ["/bin/bash", "-c"]
    command:
      - |
        apt-get update -qq && apt-get install -y -qq curl iputils-ping > /dev/null 2>&1
        echo "=== Test Ray Worker Network Test ==="
        echo "Testing connectivity to main cluster..."

        ping -c 2 {{ target_host }} ||  echo "⚠ Cannot ping {{ target_host }}"
        timeout 2 bash -c "</dev/tcp/{{ target_host }}/{{ target_head_port }}" && echo "✓ {{ target_host }}:{{ target_head_port }} reachable" || echo "✗ {{ target_host }}:{{ target_head_port }} unreachable"
        {% if services.health.enabled %}
          timeout 2 bash -c "</dev/tcp/health/{{ services.health.port }}" && echo "✓ health:{{ services.health.port }} reachable" || echo "✗ health:{{ services.health.port }} unreachable"
        {% endif %}

        echo ""
        echo "Starting Ray worker node using ray.sh..."
        echo "This node is NOT in whitelist, so should start as WORKER automatically"

        export USE_CONDA_ENV=1
        /app/ray.sh
    depends_on:
      - {{ target_host }}
{% if services.health.enabled %}
      - health
{% endif %}
    ports:
      - "{{ cluster_test.worker_node_manager_port }}:{{ cluster_test.worker_node_manager_port }}"
      - "{{ cluster_test.worker_object_manager_port }}:{{ cluster_test.worker_object_manager_port }}"
      - "{{ cluster_test.worker_min_worker_port }}-{{ cluster_test.worker_max_worker_port }}:{{ cluster_test.worker_min_worker_port }}-{{ cluster_test.worker_max_worker_port }}"
    networks:
      - test-network

{% if ray_target == "gpu" %}
  test-ray-worker-cpu:
    <<: *ray
    image: {{ cpu_image }}
    container_name: {{ project.name }}-test-worker-cpu
    hostname: test-ray-worker-cpu
    restart: "no"
    shm_size: '1gb'
    extra_hosts:
      - "ray-cpu:{{ host.ip_address }}"
      - "health:{{ host.ip_address }}"
    environment:
      <<: *ray-environment
      RAY_HEAD_PORT: {{ cpu_head_port }}
      RAY_DASHBOARD_PORT: {{ cpu_dashboard_port }}
      RAY_CLIENT_PORT: {{ cpu_client_port }}
      NODE_MANAGER_PORT: {{ cluster_test.worker_cpu_node_manager_port }}
      OBJECT_MANAGER_PORT: {{ cluster_test.worker_cpu_object_manager_port }}
      MIN_WORKER_PORT: {{ cluster_test.worker_cpu_min_worker_port }}
      MAX_WORKER_PORT: {{ cluster_test.worker_cpu_max_worker_port }}
      RAY_NUM_CPUS: "2"
      HEAD_ADDRESS: "ray-cpu:{{ cpu_head_port }}"
    volumes:
      - ../entrypoints/ray.sh:/app/ray.sh:ro
      - ../_build/logs/test-worker-cpu/tmp-ray:/tmp/ray
    user: root
    entrypoint: ["/bin/bash", "-c"]
    command:
      - |
        apt-get update -qq && apt-get install -y -qq curl iputils-ping > /dev/null 2>&1
        echo "=== Test Ray Worker (CPU Head) Network Test ==="
        echo "Testing connectivity to CPU head..."

        ping -c 2 ray-cpu ||  echo "⚠ Cannot ping ray-cpu"
        timeout 2 bash -c "</dev/tcp/ray-cpu/{{ cpu_head_port }}" && echo "✓ ray-cpu:{{ cpu_head_port }} reachable" || echo "✗ ray-cpu:{{ cpu_head_port }} unreachable"
        {% if services.health.enabled %}
          timeout 2 bash -c "</dev/tcp/health/{{ services.health.port }}" && echo "✓ health:{{ services.health.port }} reachable" || echo "✗ health:{{ services.health.port }} unreachable"
        {% endif %}

        echo ""
        echo "Starting CPU-head validation worker using ray.sh..."

        export USE_CONDA_ENV=1
        /app/ray.sh
    depends_on:
      - ray-cpu
{% if services.health.enabled %}
      - health
{% endif %}
    ports:
      - "{{ cluster_test.worker_cpu_node_manager_port }}:{{ cluster_test.worker_cpu_node_manager_port }}"
      - "{{ cluster_test.worker_cpu_object_manager_port }}:{{ cluster_test.worker_cpu_object_manager_port }}"
      - "{{ cluster_test.worker_cpu_min_worker_port }}-{{ cluster_test.worker_cpu_max_worker_port }}:{{ cluster_test.worker_cpu_min_worker_port }}-{{ cluster_test.worker_cpu_max_worker_port }}"
    networks:
      - test-network
{% endif %}

networks:
  ray-network:
    driver: bridge
    ipam:
      config:
        - subnet: {{ network.subnet }}

  test-network:
    driver: bridge
    ipam:
      config:
        - subnet: {{ cluster_test.test_network_subnet }}

volumes:
  mlflow_data:
  postgres_data:
  ray_data: